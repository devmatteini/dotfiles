#!/usr/bin/env bash

# https://docs.docker.com/ai/sandboxes/

set -euo pipefail

RESET="\e[0m"
BOLD="\e[1;37m"

if ! command -v docker >/dev/null; then
	echo "Missing docker"
	exit 1
fi

sudo apt install -y docker-sbx

sudo usermod -aG kvm $USER

echo -e "${BOLD}[docker-sandbox] Remember to log out and log back in so that kvm group membership is re-evaluated${RESET}"
